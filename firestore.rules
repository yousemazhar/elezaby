rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Products and categories are public reads, admin-only writes
    match /products/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /categories/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Cart items belong to the owning user
    match /carts/{uid}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Favorites belong to the owning user
    match /favorites/{uid}/items/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Addresses belong to the owning user
    match /users/{uid}/addresses/{addressId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Orders: user can create their own, read their own
    match /orders/{orderId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
